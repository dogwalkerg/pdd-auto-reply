# ==========================================
# 拼多多自动回复系统 - 环境变量示例文件
# ------------------------------------------
# 用途：一键脚本（build.sh / deploy.sh / update.sh）与 docker-compose.yml 共用的环境变量。
# 使用：首次部署时由 deploy.sh 自动复制为 .env；也可手动 `cp .env.example .env` 后按需修改。
# 规范：禁止在代码 / 编排中写死 localhost，所有地址与端口一律经本文件（环境变量）管理（规范 21 / 需求 25.4）。
# ==========================================

# ===== Compose 项目标识（用于精确清理本项目容器 / 镜像 / 网络，避免误伤其它项目）=====
COMPOSE_PROJECT_NAME=pdd-auto-reply

# ===== 运行环境 =====
ENVIRONMENT=production

# ===== MySQL 数据库配置（Docker 内置，首次启动自动创建；时区固定北京时间 +08:00）=====
# 说明：compose 以 MYSQL_PASSWORD 作为 root 密码（MYSQL_ROOT_PASSWORD），并据此初始化数据库。
MYSQL_PASSWORD=pdd_root_2026
MYSQL_DATABASE=pdd_auto_reply
MYSQL_USER=root
MYSQL_HOST=mysql
MYSQL_PORT=3306
# 宿主机映射端口（仅本机调试用，生产可按需调整或在 compose 中移除映射）
MYSQL_HOST_PORT=3306

# ===== Redis 缓存配置（Docker 内置；REDIS_PASSWORD 为空则不启用密码）=====
REDIS_PASSWORD=pdd_redis_2026
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_HOST_PORT=6379

# ===== 对外暴露端口（如与本机其它服务冲突，请在此调整）=====
BACKEND_WEB_PORT=8089
WEBSOCKET_PORT=8090
SCHEDULER_PORT=8091
# 前端 nginx 对外端口（默认 80）
FRONTEND_HOST_PORT=80

# ===== 服务间通信地址（容器网络内部使用服务名，禁止写死 localhost，需求 25.4）=====
BACKEND_WEB_SERVICE_URL=http://backend:8089
WEBSOCKET_SERVICE_URL=http://websocket:8090
SCHEDULER_SERVICE_URL=http://scheduler:8091
# 前端 nginx 反向代理后端的地址（用 docker 服务名）
BACKEND_API_URL=http://backend:8089

# ===== 安全密钥（生产务必修改为强随机值，不要使用默认占位）=====
JWT_SECRET_KEY=change-me-in-env
DATA_ENCRYPT_KEY=change-me-data-encrypt-key
# 服务间内部接口调用共享密钥（在线聊天实时推送等内部回调用，需求 14）
INTERNAL_SERVICE_TOKEN=change-me-internal-service-token

# ===== 初始超级管理员（仅在数据库无任何用户时，首次启动自检自动创建）=====
# 生产环境务必修改为强密码，首次登录后请及时在「个人设置」中修改。
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123

# ===== Playwright 登录相关（账号密码登录默认非无头以便人工验证；验证码并发数）=====
BROWSER_HEADLESS=false
MAX_CAPTCHA_CONCURRENT=1
# Playwright 浏览器持久化用户数据目录（保存登录态，减少重复人工验证）。
# 须与 docker-compose.yml 中 websocket 服务挂载的持久化卷路径一致。
PLAYWRIGHT_USER_DATA_DIR=/app/websocket/browser_data

# ===== 日志级别 =====
LOG_LEVEL=INFO
